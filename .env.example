# Postgres superuser (used for admin tasks and to bootstrap per-service DBs).
# Services do NOT connect with this user.
POSTGRES_USER=energy
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Per-service databases.
# Add a service name here -> on next fresh `up`, an init script creates
#   database <name>_service  owned by  role <name>_service
# Comma-separated, no spaces.
SERVICE_DBS=user,device,alert,insight
SERVICE_DB_PASSWORD=replace-me

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=replace-me
PGADMIN_PORT=5050

# InfluxDB
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=replace-me
INFLUXDB_INIT_ORG=home-energy-tracker
INFLUXDB_INIT_BUCKET=usage-bucket
# Generate with: openssl rand -hex 32
INFLUXDB_INIT_ADMIN_TOKEN=replace-me

# Keycloak
KEYCLOAK_DB_PASSWORD=replace-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=replace-me

# Keycloak client secret for the 'energy-sensors' client (Credentials tab in admin UI)
ENERGY_SENSORS_CLIENT_SECRET=replace-me
